# ─────────────────────────────────────────
#  TutorFinder API Server — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8080

# ─── MongoDB Atlas ─────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/tutorfinder?retryWrites=true&w=majority

# ─── JWT Secrets ───────────────────────────
# Generate strong random strings (min 32 chars each):
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHAR_HEX_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cloudinary ────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Resend (Email) ────────────────────────
# Get from: https://resend.com/api-keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified domain or use Resend's sandbox: onboarding@resend.dev
EMAIL_FROM=noreply@tutorfinder.pk

# ─── Client URL ────────────────────────────
# Development (Replit):
CLIENT_URL=https://YOUR_REPLIT_DOMAIN.replit.dev
# Production:
# CLIENT_URL=https://tutorfinder.pk

# ─── UltraMsg (WhatsApp OTP) ───────────────
# Get from: https://ultramsg.com/dashboard
# Free tier: 200 messages/month (for Phase 3 phone verification)
ULTRAMSG_TOKEN=your_ultramsg_token
ULTRAMSG_INSTANCE_ID=your_instance_id
